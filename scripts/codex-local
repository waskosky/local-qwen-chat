#!/usr/bin/env bash
set -Eeuo pipefail

usage() {
  cat <<'EOF'
Start Codex with a local Qwen model.

Usage: local-qwen-codex [q4|q6] [codex arguments...]

The requested model is selected through Local Qwen Chat, the command waits for
it to become ready, and Codex is started against the compatibility API.

Environment:
  LOCAL_QWEN_MODEL=q4|q6       Default model when none is specified
  LOCAL_QWEN_URL=URL           Local Qwen Chat URL (default: http://127.0.0.1:8090)
  LOCAL_QWEN_READY_TIMEOUT=N   Ready timeout in seconds (default: 600)
  LOCAL_QWEN_RUST_LOG=FILTER   Native Codex log filter (default: error)
  LOCAL_QWEN_LOG_MAX_BYTES=N   Rotate codex-tui.log at this size (default: 52428800)
  LOCAL_QWEN_FULL_CAPTURE=1    Opt in to a complete terminal input/output recording
  LOCAL_QWEN_CODEX_MODEL_CATALOG=FILE  Use a prebuilt Codex model catalog
  CODEX_BIN=PATH               Codex executable (default: codex from PATH)
EOF
}

rotate_codex_log() {
  local log_file="$1" max_bytes="$2" size generation
  [[ -f "$log_file" ]] || return 0
  size="$(stat -c '%s' "$log_file" 2>/dev/null || printf '0')"
  (( size >= max_bytes )) || return 0

  rm -f -- "${log_file}.3"
  for generation in 2 1; do
    if [[ -f "${log_file}.${generation}" ]]; then
      mv -- "${log_file}.${generation}" "${log_file}.$((generation + 1))"
    fi
  done
  mv -- "$log_file" "${log_file}.1"
}

model="${LOCAL_QWEN_MODEL:-q4}"
case "${1:-}" in
  q4|q6)
    model="$1"
    shift
    ;;
  --help|-h)
    usage
    exit 0
    ;;
esac

case "$model" in
  q4) model_id="qwen3.6-27b-q4" ;;
  q6) model_id="qwen3.6-27b-q6" ;;
  *)
    printf 'LOCAL_QWEN_MODEL must be q4 or q6, not %s.\n' "$model" >&2
    exit 2
    ;;
esac

base_url="${LOCAL_QWEN_URL:-http://127.0.0.1:8090}"
base_url="${base_url%/}"
ready_timeout="${LOCAL_QWEN_READY_TIMEOUT:-600}"
codex_bin="${CODEX_BIN:-}"
state_root="${LOCAL_QWEN_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/local-qwen-chat}"
codex_log_dir="${LOCAL_QWEN_CODEX_LOG_DIR:-$state_root/codex}"
log_max_bytes="${LOCAL_QWEN_LOG_MAX_BYTES:-52428800}"

if [[ ! "$ready_timeout" =~ ^[1-9][0-9]*$ ]]; then
  printf 'LOCAL_QWEN_READY_TIMEOUT must be a positive integer.\n' >&2
  exit 2
fi
if [[ ! "$log_max_bytes" =~ ^[1-9][0-9]*$ ]]; then
  printf 'LOCAL_QWEN_LOG_MAX_BYTES must be a positive integer.\n' >&2
  exit 2
fi
if ! command -v curl >/dev/null 2>&1; then
  printf 'curl is required. Install it with your system package manager.\n' >&2
  exit 1
fi
if [[ -n "$codex_bin" ]]; then
  if ! command -v "$codex_bin" >/dev/null 2>&1; then
    printf 'CODEX_BIN is not executable: %s\n' "$codex_bin" >&2
    exit 1
  fi
elif command -v codex >/dev/null 2>&1; then
  codex_bin="$(command -v codex)"
elif [[ -x /opt/local-qwen-chat/codex/bin/codex \
  && -x /opt/local-qwen-chat/node/bin/node ]]; then
  export PATH="/opt/local-qwen-chat/node/bin:$PATH"
  codex_bin="/opt/local-qwen-chat/codex/bin/codex"
else
  cat >&2 <<'EOF'
Codex CLI was not found. Either re-run the Local Qwen installer with
--with-codex, or install Codex for your user:

  npm install --global @openai/codex
EOF
  exit 1
fi

get_status() {
  curl --silent --show-error --fail --max-time 5 "$base_url/api/models"
}

status="$(get_status 2>/dev/null || true)"
if [[ -z "$status" ]]; then
  cat >&2 <<EOF
Local Qwen Chat is not responding at $base_url.
Start it with:

  sudo systemctl start qwen-chat-ui qwen-model-selector
EOF
  exit 1
fi

if [[ "$status" != *"\"servingModel\":\"$model\""* ]]; then
  printf 'Selecting %s...\n' "$model_id"
  response="$({
    curl --silent --show-error --max-time 70 \
      --request POST \
      --header 'Content-Type: application/json' \
      --header 'X-Local-Qwen-Action: switch-model' \
      --data "{\"model\":\"$model\"}" \
      --write-out $'\n%{http_code}' \
      "$base_url/api/models"
  } 2>&1)" || {
    printf 'Could not request the model switch: %s\n' "$response" >&2
    exit 1
  }
  http_status="${response##*$'\n'}"
  response_body="${response%$'\n'*}"
  if [[ "$http_status" != "202" ]]; then
    printf 'Model switch failed (HTTP %s): %s\n' "$http_status" "$response_body" >&2
    exit 1
  fi

  printf 'Waiting for %s to become ready' "$model_id"
  deadline=$((SECONDS + ready_timeout))
  while (( SECONDS < deadline )); do
    status="$(get_status 2>/dev/null || true)"
    if [[ "$status" == *"\"servingModel\":\"$model\""* ]]; then
      break
    fi
    printf '.'
    sleep 2
  done
  printf '\n'
  if [[ "$status" != *"\"servingModel\":\"$model\""* ]]; then
    printf '%s did not become ready within %s seconds. Run local-qwen-diagnose.\n' \
      "$model_id" "$ready_timeout" >&2
    exit 1
  fi
fi

export CODEX_OSS_BASE_URL="$base_url/v1"
export RUST_LOG="${RUST_LOG:-${LOCAL_QWEN_RUST_LOG:-error}}"
umask 077
mkdir -p -- "$codex_log_dir"
chmod 0700 "$state_root" "$codex_log_dir" 2>/dev/null || true
rotate_codex_log "$codex_log_dir/codex-tui.log" "$log_max_bytes"

if [[ -n "${LOCAL_QWEN_CODEX_MODEL_CATALOG:-}" ]]; then
  model_catalog="$LOCAL_QWEN_CODEX_MODEL_CATALOG"
  if [[ ! -r "$model_catalog" ]]; then
    printf 'LOCAL_QWEN_CODEX_MODEL_CATALOG is not readable: %s\n' "$model_catalog" >&2
    exit 1
  fi
else
  catalog_dir="$state_root/catalogs"
  model_catalog="$catalog_dir/$model.json"
  catalog_temp="$model_catalog.tmp.$$"
  mkdir -p -- "$catalog_dir"
  chmod 0700 "$catalog_dir" 2>/dev/null || true
  if ! curl --silent --show-error --fail --max-time 10 \
    --output "$catalog_temp" "$base_url/v1/models"; then
    rm -f -- "$catalog_temp"
    printf 'Could not snapshot local model metadata from %s/v1/models.\n' "$base_url" >&2
    exit 1
  fi
  chmod 0600 "$catalog_temp"
  mv -- "$catalog_temp" "$model_catalog"
fi

codex_command=(
  "$codex_bin"
  --oss
  --local-provider lmstudio
  --model "$model_id"
  -c "model_catalog_json=\"$model_catalog\""
  -c "log_dir=\"$codex_log_dir\""
  "$@"
)

printf 'Starting Codex with %s via %s\n' "$model_id" "$CODEX_OSS_BASE_URL"
printf 'Model metadata: %s\n' "$model_catalog"
printf 'Native Codex log: %s/codex-tui.log\n' "$codex_log_dir"

if [[ "${LOCAL_QWEN_FULL_CAPTURE:-0}" == "1" ]]; then
  if ! command -v script >/dev/null 2>&1; then
    printf 'LOCAL_QWEN_FULL_CAPTURE requires the util-linux script command.\n' >&2
    exit 1
  fi
  capture_dir="$state_root/captures"
  mkdir -p -- "$capture_dir"
  chmod 0700 "$capture_dir" 2>/dev/null || true
  capture_stamp="$(date -u +%Y%m%dT%H%M%SZ)-$$-$model"
  capture_file="$capture_dir/$capture_stamp.io"
  timing_file="$capture_dir/$capture_stamp.timing"
  printf 'Full capture enabled: %s\n' "$capture_file"
  printf 'Warning: this records prompts, pasted source, terminal output, and secrets.\n'
  printf -v quoted_command '%q ' "${codex_command[@]}"
  set +e
  script --quiet --flush --return --logging-format advanced \
    --log-io "$capture_file" --log-timing "$timing_file" \
    --command "$quoted_command"
  capture_status=$?
  set -e
  printf 'Full capture saved: %s\n' "$capture_file"
  exit "$capture_status"
fi

exec "${codex_command[@]}"
