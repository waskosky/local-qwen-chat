#!/usr/bin/env bash
set -euo pipefail

config_dir="${LOCAL_QWEN_CONFIG_DIR:-/etc/local-qwen-chat}"
systemctl_bin="${SYSTEMCTL_BIN:-/usr/bin/systemctl}"
# shellcheck source=/dev/null
source "$config_dir/paths.env"

state_file="${LOCAL_QWEN_STATE_FILE:-/var/lib/local-qwen-chat/active-model}"
selected=q4

if [[ -r "$state_file" ]]; then
  selected="$(tr -d '[:space:]' < "$state_file")"
fi

if [[ "$selected" == "q6" && ! -r "$QWEN_Q6_MODEL" && -r "$QWEN_Q4_MODEL" ]]; then
  printf 'Q6 was selected but is not installed; falling back to Q4.\n' >&2
  selected=q4
  printf 'q4\n' > "$state_file"
elif [[ "$selected" == "q4" && ! -r "$QWEN_Q4_MODEL" && -r "$QWEN_Q6_MODEL" ]]; then
  printf 'Q4 was selected but is not installed; falling back to Q6.\n' >&2
  selected=q6
  printf 'q6\n' > "$state_file"
elif [[ ! -r "$QWEN_Q4_MODEL" && ! -r "$QWEN_Q6_MODEL" ]]; then
  printf 'Neither Q4 nor Q6 is installed. Re-run install.sh.\n' >&2
  exit 1
fi

case "$selected" in
  q4)
    unit=qwen36-q4.service
    other=qwen36-q6.service
    ;;
  q6)
    unit=qwen36-q6.service
    other=qwen36-q4.service
    ;;
  *)
    selected=q4
    unit=qwen36-q4.service
    other=qwen36-q6.service
    printf 'q4\n' > "$state_file"
    ;;
esac

printf 'Starting selected local Qwen model: %s\n' "$selected"
"$systemctl_bin" stop "$other"
exec "$systemctl_bin" start "$unit"
