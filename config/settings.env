# Runtime tuning. Re-running install.sh preserves your installed copy.
QWEN_CTX_SIZE=32768
QWEN_PARALLEL=1
QWEN_THREADS=0
QWEN_THREADS_BATCH=0
QWEN_FIT_TARGET=1536
QWEN_FLASH_ATTN=on
QWEN_CACHE_TYPE_K=q8_0
QWEN_CACHE_TYPE_V=q8_0
QWEN_REASONING_FORMAT=deepseek
QWEN_REASONING_BUDGET=512
QWEN_MTP=0
QWEN_EXTRA_ARGS=""

QWEN_HOST=127.0.0.1
QWEN_PORT=8080
CHAT_HOST=127.0.0.1
CHAT_PORT=8090
