#!/usr/bin/env bash
set -u

usage() {
  cat <<'EOF'
Create a bounded diagnostic report for local Codex/Qwen context failures.

Usage: local-qwen-context-report [--since TIME] [--output FILE]

Options:
  --since TIME   journalctl-compatible start time (default: 2 hours ago)
  --output FILE  write to this path instead of the private state directory
  --help         show this help

The report includes metadata, resource state, token/error lines, log sizes, and
rollout paths. It does not copy complete prompts or transcript bodies.
EOF
}

since="${LOCAL_QWEN_REPORT_SINCE:-2 hours ago}"
output=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --since)
      [[ $# -ge 2 ]] || { printf '%s\n' '--since requires a value.' >&2; exit 2; }
      since="$2"
      shift 2
      ;;
    --output)
      [[ $# -ge 2 ]] || { printf '%s\n' '--output requires a value.' >&2; exit 2; }
      output="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

umask 077
state_root="${LOCAL_QWEN_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/local-qwen-chat}"
report_dir="$state_root/reports"
codex_home="${CODEX_HOME:-$HOME/.codex}"
codex_log_dir="${LOCAL_QWEN_CODEX_LOG_DIR:-$state_root/codex}"
base_url="${LOCAL_QWEN_URL:-http://127.0.0.1:8090}"
base_url="${base_url%/}"
mkdir -p -- "$report_dir"
chmod 0700 "$state_root" "$report_dir" 2>/dev/null || true
if [[ -z "$output" ]]; then
  output="$report_dir/context-$(date -u +%Y%m%dT%H%M%SZ)-$$.log"
else
  mkdir -p -- "$(dirname -- "$output")"
fi

section() {
  printf '\n===== %s =====\n' "$1"
}

recent_files() {
  local root="$1" pattern="$2" limit="$3"
  [[ -d "$root" ]] || return 0
  find "$root" -type f -name "$pattern" -printf '%T@ %s %p\n' 2>/dev/null \
    | sort -nr | head -n "$limit"
}

report_body() {
  printf 'Local Qwen context diagnostic\n'
  printf 'Created (UTC): %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  printf 'Host: %s\n' "$(hostname 2>/dev/null || printf unknown)"
  printf 'Journal range: since %s\n' "$since"
  printf 'Privacy: full prompt and transcript bodies are referenced, not copied.\n'

  section 'Compatibility API metadata'
  printf 'GET %s/v1/models\n' "$base_url"
  curl --silent --show-error --max-time 5 "$base_url/v1/models" 2>&1 || true
  printf '\nGET %s/api/models\n' "$base_url"
  curl --silent --show-error --max-time 5 "$base_url/api/models" 2>&1 || true
  printf '\n'

  section 'Service state'
  systemctl show \
    qwen-model-selector.service qwen-chat-ui.service qwen36-q4.service qwen36-q6.service \
    --property=Id --property=ActiveState --property=SubState --property=MainPID \
    --property=NRestarts --property=MemoryCurrent --property=MemoryPeak \
    --property=ExecMainStartTimestamp --no-pager 2>&1 || true

  section 'Memory and disk'
  free -h 2>&1 || true
  df -h /var/lib/local-qwen-chat /opt/local-qwen-chat "$state_root" 2>/dev/null \
    || df -h / 2>&1 || true
  printf '\nCodex state size:\n'
  du -sh "$codex_home" "$codex_home/sessions" "$state_root" 2>/dev/null || true
  journalctl --disk-usage 2>&1 || true

  if command -v nvidia-smi >/dev/null 2>&1; then
    section 'NVIDIA GPU state'
    nvidia-smi \
      --query-gpu=index,name,memory.total,memory.used,memory.free,utilization.gpu \
      --format=csv,noheader 2>&1 || true
  fi

  section 'Active Codex processes and rollout files'
  found_codex=0
  for proc_dir in /proc/[0-9]*; do
    [[ -r "$proc_dir/cmdline" ]] || continue
    if ! tr '\0' ' ' < "$proc_dir/cmdline" 2>/dev/null | grep -Eq '(^|[/ ])codex([ /]|$)'; then
      continue
    fi
    pid="${proc_dir##*/}"
    found_codex=1
    ps -o pid=,etimes=,rss=,comm= -p "$pid" 2>/dev/null || true
    for fd in "$proc_dir"/fd/*; do
      target="$(readlink "$fd" 2>/dev/null || true)"
      case "$target" in
        "$codex_home"/sessions/*.jsonl)
          bytes="$(stat -c '%s' "$target" 2>/dev/null || printf '?')"
          printf '  rollout (%s bytes): %s\n' "$bytes" "$target"
          ;;
      esac
    done
  done
  if [[ "$found_codex" == "0" ]]; then
    printf 'No active Codex process detected.\n'
  fi

  section 'Recent rollout inventory'
  if [[ -d "$codex_home/sessions" ]]; then
    printf 'Newest files (epoch-mtime bytes path):\n'
    recent_files "$codex_home/sessions" 'rollout-*.jsonl' 10
    printf '\nContext-related match counts in the last 5 MiB of each newest rollout:\n'
    while read -r _mtime _bytes rollout; do
      [[ -n "${rollout:-}" ]] || continue
      count="$(tail -c 5242880 -- "$rollout" 2>/dev/null \
        | grep -Eaci 'exceed_context_size_error|exceeds the available context size|model metadata.*not found|auto.?compact' || true)"
      printf '%s  %s\n' "$count" "$rollout"
    done < <(recent_files "$codex_home/sessions" 'rollout-*.jsonl' 10)
  else
    printf 'No Codex rollout directory found at %s/sessions.\n' "$codex_home"
  fi

  section 'Native Codex warnings and errors'
  codex_log="$codex_log_dir/codex-tui.log"
  if [[ -f "$codex_log" ]]; then
    printf 'Log: %s (%s bytes)\n' "$codex_log" "$(stat -c '%s' "$codex_log" 2>/dev/null || printf '?')"
    printf 'Filtered tail (may contain workspace details):\n'
    tail -n 2000 -- "$codex_log" 2>/dev/null \
      | grep -Eai 'error|warn|context|token|compact|mcp|provider' | tail -n 200 || true
  else
    printf 'No native log yet at %s. Start Codex with local-qwen-codex.\n' "$codex_log"
  fi

  section 'llama.cpp and compatibility errors/token timings'
  journalctl \
    -u qwen-chat-ui.service -u qwen36-q4.service -u qwen36-q6.service \
    --since "$since" --no-pager -o short-iso 2>/dev/null \
    | grep -Eai 'error|warn|exceed|context|n_prompt_tokens|prompt (eval|tokens)|tokens per second|slot.*(prompt|token)' \
    | tail -n 500 || true

  section 'Known MCP logs'
  found_mcp=0
  for mcp_log in "$HOME/games/rai/out/mcp.log" "$HOME/.codex/mcp.log"; do
    [[ -f "$mcp_log" ]] || continue
    found_mcp=1
    printf '\nLog: %s (%s bytes)\n' "$mcp_log" "$(stat -c '%s' "$mcp_log" 2>/dev/null || printf '?')"
    printf 'Filtered tail (may contain tool arguments or workspace details):\n'
    tail -n 2000 -- "$mcp_log" 2>/dev/null \
      | grep -Eai 'error|warn|context|token|compact|timeout|fail|exception' | tail -n 200 || true
  done
  if [[ "$found_mcp" == "0" ]]; then
    printf 'No known MCP log files found. Native Codex logs still include MCP client failures.\n'
  fi

  section 'Opt-in full terminal captures'
  if [[ -d "$state_root/captures" ]]; then
    recent_files "$state_root/captures" '*.io' 10
  else
    printf 'None. Set LOCAL_QWEN_FULL_CAPTURE=1 only when complete I/O capture is needed.\n'
  fi

  section 'Interpretation'
  printf '%s\n' \
    'Compare llama.cpp n_prompt_tokens with context_window and auto_compact_token_limit.' \
    'A server-side exceed error means the hard llama.cpp window filled before Codex compacted.' \
    'Large MCP tool schemas/results can cause sharp jumps; prefer compact MCP response modes.' \
    'Restart Codex after context metadata changes so the process reloads the model catalog.'
}

report_body 2>&1 | tee "$output"
printf '\nReport saved to %s\n' "$output"
